# Provisum Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.

# ── Environment ──────────────────────────────────────────────
# Valid values: development | demo | preview | production
# Controls demo mode, safety guards, and environment banner.
# In Vercel: set to "production" for Production env, "demo" for Preview env.
PROVISUM_ENV=development
# Client-side mirror (Next.js only exposes NEXT_PUBLIC_ vars to the browser)
NEXT_PUBLIC_PROVISUM_ENV=development

# ── Database ─────────────────────────────────────────────────
# Supabase pooled connection string (port 6543, transaction mode)
# IMPORTANT: Use the DEMO database locally, never production.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Supabase Auth ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── AI ───────────────────────────────────────────────────────
# Anthropic Claude API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-v4-YOUR-KEY-HERE

# ── Security ─────────────────────────────────────────────────
# Encryption key for sensitive settings at rest (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# ── Email ────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Cron ─────────────────────────────────────────────────────
CRON_SECRET=your-cron-secret

# ── App URL ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Sentry ───────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o123.ingest.sentry.io/456
SENTRY_AUTH_TOKEN=sntrys_your-auth-token-here
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
