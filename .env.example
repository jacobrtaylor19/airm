# AIRM Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.

# Application mode (development | production)
NODE_ENV=development

# Anthropic Claude API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-v4-YOUR-KEY-HERE

# SQLite database location
# Development: relative path in project root
# Production (Render): file:///data/airm.db (persistent volume)
DATABASE_URL=file:./airm.db
